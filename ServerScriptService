	local function SetupDemo()
		--Name the model "Foundatiom"
		local demoStructure = Instance.new("Model")
		demoStructure.Name = TARGET_MODEL_NAME
		demoStructure.Parent = Workspace

		-- Build brick wall
		for y = 1, 8 do
			for x = -6, 6 do
				local brick = Instance.new("Part")
				brick.Size = Vector3.new(4, 2, 2)
				-- Start y offset at 1 so the bottom bricks touch the ground (Y=1)
				brick.Position = Vector3.new(x * 4, (y * 2) - 1, 0)

				if y % 2 == 0 then
					brick.Position = brick.Position + Vector3.new(2, 0, 0)
				end

				-- All parts inside the "Foundation" model must be anchored
				brick.Anchored = true 
				brick.BrickColor = BrickColor.new("Bright red")
				brick.Material = Enum.Material.Brick
				brick.Parent = demoStructure
			end
		end

		print("Demo Structure Built! Click on any brick to explode it.")
	end

